{
  "name": "@promptflow/cli",
  "version": "0.1.0",
  "description": "Command-line interface for PromptFlow",
  "type": "module",
  "bin": {
    "promptflow": "./dist/bin.js",
    "pf": "./dist/bin.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@promptflow/core": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "inquirer": "^9.2.15",
    "fs-extra": "^11.2.0",
    "yaml": "^2.4.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/fs-extra": "^11.0.4",
    "vitest": "^1.3.0",
    "@vitest/coverage-v8": "^1.3.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/promptflow/promptflow.git",
    "directory": "packages/cli"
