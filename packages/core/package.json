{
  "name": "@promptflow/core",
  "version": "0.1.0",
  "description": "Core workflow engine and provider abstraction for PromptFlow",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.22.4",
    "p-retry": "^6.2.0",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "vitest": "^1.3.0",
    "@vitest/coverage-v8": "^1.3.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "openai": "^4.0.0",
    "@anthropic-ai/sdk": "^0.18.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/promptflow/promptflow.git",
    "directory": "packages/core"
  }
}
